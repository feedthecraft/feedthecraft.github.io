onEvent('recipes', event => {

  event.shapeless(Item.of('immersiveengineering:ingot_steel'), ['beyond_earth:steel_ingot']).id('tnp_convert:steel_ingot_convert')
  event.shapeless(Item.of('immersiveengineering:storage_steel'), ['beyond_earth:steel_block']).id('tnp_convert:steel_block_convert')
  event.shapeless(Item.of('immersiveengineering:nugget_steel'), ['beyond_earth:steel_nugget']).id('tnp_convert:steel_nugget_convert')

  event.shapeless(Item.of('immersiveengineering:raw_uranium'), ['bno:raw_uranium']).id('convert_recipe_ignore:raw_uranium_convert')
  event.shapeless(Item.of('immersiveengineering:storage_uranium'), ['biggerreactors:uranium_block']).id('convert_recipe_ignore:uranium_block_convert')
  event.shapeless(Item.of('immersiveengineering:ingot_uranium'), ['biggerreactors:uranium_ingot']).id('convert_recipe_ignore:uranium_ingot_convert')
  event.shapeless(Item.of('immersiveengineering:dust_uranium'), ['biggerreactors:uranium_dust']).id('convert_recipe_ignore:uranium_dust_convert')

});